generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id                String   @id @default(uuid())
  name              String
  icon              String
  description       String   @db.Text
  steps             Json     // [{agentId, skillId, action, inputFrom?}]
  startTime         String?
  endTime           String?
  scheduled         Boolean  @default(false)
  scheduledEnabled  Boolean  @default(false)
  cron              String?
  persistent        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Assistant {
  id                String   @id @default(uuid())
  assistantId       String   @unique
  name              String
  role              String
  description       String   @db.Text
  accent            String
  systemPrompt      String   @db.Text
  skills            Json
  item              String
  catColors         Json
  messages          String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WorkflowRun {
  id                String   @id @default(uuid())
  workflowId        String?
  workflowName      String
  agentId           String
  skillId           String
  stepIndex         Int      @default(0)
  summary           String   @db.Text
  result            String   @db.Text
  status            String
  executedAt        DateTime @default(now())
  duration          Int?
  createdAt         DateTime @default(now())
}
