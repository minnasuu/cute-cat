# Database
# Compose 里 backend 的 DATABASE_URL 由 POSTGRES_PASSWORD 自动生成；勿在 .env 里另写一套不一致的 DATABASE_URL。
# 密码勿含未转义的 #（在 .env 里 # 会当成注释）；含特殊字符时优先只用 POSTGRES_PASSWORD，不要用复杂 URL。
POSTGRES_PASSWORD=postgres

# JWT Auth
JWT_SECRET=your-jwt-secret-change-in-production

# AI Models
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.0-flash
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-plus
DEFAULT_AI_MODEL=qwen

# SMTP Email (used for verification codes + cat emails)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Beta Access (comma-separated invite codes, e.g. CAT2026,MEOW888)
BETA_CODES=CAT2026

# Frontend（邮件里的链接、部分回调会用到，线上改成你的域名，含协议）
FRONTEND_URL=http://localhost
