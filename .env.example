# Database（Docker Compose 会读 POSTGRES_PASSWORD；与 db 服务密码一致即可）
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/cute_cat

# JWT Auth
JWT_SECRET=your-jwt-secret-change-in-production

# AI Models
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.0-flash
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
DEFAULT_AI_MODEL=qwen

# SMTP Email (used for verification codes + cat emails)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Beta Access (comma-separated invite codes, e.g. CAT2026,MEOW888)
BETA_CODES=CAT2026

# Frontend（邮件里的链接、部分回调会用到，线上改成你的域名，含协议）
FRONTEND_URL=http://localhost
